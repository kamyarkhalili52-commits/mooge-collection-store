        .author-avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--cream2); border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
        .author-name { font-size: 0.9rem; font-weight: 700; color: var(--brown-dark); }
        .author-date { font-size: 0.75rem; color: var(--text-muted); }

        /* ===== INSTAGRAM ===== */
        #instagram { padding: 100px 60px; background: var(--cream2); }
        .instagram-inner { max-width: 1200px; margin: 0 auto; }
        .instagram-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; }
        .insta-item { aspect-ratio: 1; border-radius: 8px; background: var(--border); overflow: hidden; cursor: pointer; position: relative; }
        .insta-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 2rem; background: linear-gradient(135deg, var(--cream2), var(--border)); transition: transform 0.4s; }
        .insta-item:hover .insta-placeholder { transform: scale(1.1); }
        .insta-overlay { position: absolute; inset: 0; background: rgba(92, 74, 50, 0.7); display: flex; align-items: center; justify-content: center; color: white; font-size: 1.4rem; opacity: 0; transition: opacity 0.3s; }
        .insta-item:hover .insta-overlay { opacity: 1; }

        /* ===== NEWSLETTER ===== */
        #newsletter { padding: 80px 60px; background: var(--cream); }
        .newsletter-inner { max-width: 600px; margin: 0 auto; text-align: center; }
        .newsletter-form { display: flex; margin-top: 30px; border: 1.5px solid var(--border); border-radius: 6px; overflow: hidden; background: white; transition: border-color 0.3s; }
        .newsletter-form:focus-within { border-color: var(--brown); }
        .newsletter-input { flex: 1; padding: 15px 20px; border: none; outline: none; font-family: 'Vazirmatn', sans-serif; font-size: 0.9rem; background: transparent; color: var(--text); }
        .newsletter-btn { padding: 15px 28px; background: var(--brown-dark); color: white; border: none; font-family: 'Vazirmatn', sans-serif; font-size: 0.85rem; font-weight: 700; cursor: pointer; transition: background 0.3s; letter-spacing: 1px; white-space: nowrap; }
        .newsletter-btn:hover { background: var(--brown); }

        /* ===== ABOUT ===== */
        #about { padding: 100px 60px; background: white; }
        .about-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
        .about-img-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .about-img-item { border-radius: 10px; overflow: hidden; background: var(--cream2); }
        .about-img-item:first-child { grid-column: span 2; }
        .about-placeholder { width: 100%; display: flex; align-items: center; justify-content: center; font-size: 3rem; background: linear-gradient(135deg, var(--cream2), var(--border)); }
        .about-placeholder.tall { height: 240px; }
        .about-placeholder.short { height: 160px; }
        .about-tag { font-size: 0.72rem; letter-spacing: 4px; text-transform: uppercase; color: var(--brown); margin-bottom: 16px; }
        .about-title { font-size: 2.2rem; font-weight: 900; color: var(--brown-dark); line-height: 1.3; margin-bottom: 20px; }
        .about-text { color: var(--text-muted); font-size: 0.95rem; line-height: 2; margin-bottom: 16px; }
        .about-vals { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 32px; }
        .about-val { display: flex; align-items: flex-start; gap: 12px; padding: 16px; background: var(--cream); border-radius: 10px; border: 1px solid var(--border); }
        .about-val-icon { color: var(--brown); font-size: 1rem; margin-top: 2px; }
        .about-val-title { font-size: 0.85rem; font-weight: 700; color: var(--brown-dark); margin-bottom: 3px; }
        .about-val-desc { font-size: 0.78rem; color: var(--text-muted); line-height: 1.5; }

        /* ===== CONTACT ===== */
        #contact { padding: 100px 60px; background: var(--cream2); }
        .contact-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.2fr; gap: 60px; }
        .contact-info-title { font-size: 2rem; font-weight: 900; color: var(--brown-dark); margin-bottom: 14px; }
        .contact-info-desc { color: var(--text-muted); font-size: 0.95rem; line-height: 1.8; margin-bottom: 36px; }
        .contact-items { display: flex; flex-direction: column; gap: 14px; }
        .contact-item { display: flex; align-items: center; gap: 16px; padding: 16px 20px; background: white; border: 1px solid var(--border); border-radius: 12px; text-decoration: none; color: var(--text); transition: all 0.3s; }
        .contact-item:hover { border-color: var(--brown); background: var(--cream); transform: translateX(-6px); }
        .contact-item-icon { width: 42px; height: 42px; border-radius: 10px; background: var(--cream2); display: flex; align-items: center; justify-content: center; color: var(--brown); font-size: 1rem; }
        .contact-item-label { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 2px; }
        .contact-item-value { font-size: 0.9rem; font-weight: 600; color: var(--brown-dark); }
        .contact-form-wrap { background: white; padding: 40px; border-radius: 16px; border: 1px solid var(--border); }
        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 7px; font-weight: 500; }
        .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 13px 16px; border: 1.5px solid var(--border); border-radius: 8px; font-family: 'Vazirmatn', sans-serif; font-size: 0.9rem; color: var(--text); background: var(--cream); outline: none; transition: all 0.3s; resize: none; }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--brown); background: white; }
        .form-group textarea { height: 110px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .submit-btn { width: 100%; padding: 15px; background: var(--brown-dark); color: white; border: none; border-radius: 8px; font-family: 'Vazirmatn', sans-serif; font-size: 0.95rem; font-weight: 700; cursor: pointer; transition: all 0.3s; display: flex; align-items: center; justify-content: center; gap: 10px; letter-spacing: 1px; }
        .submit-btn:hover { background: var(--brown); transform: translateY(-2px); box-shadow: 0 10px 30px rgba(92,74,50,0.3); }

        /* ===== TRUST BADGES ===== */
        #trust { background: white; padding: 50px 60px; border-top: 1px solid var(--border); }
        .trust-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: center; gap: 50px; flex-wrap: wrap; }
        .trust-item { display: flex; flex-direction: column; align-items: center; gap: 10px; opacity: 0.6; transition: opacity 0.3s; }
        .trust-item:hover { opacity: 1; }
        .trust-icon { width: 60px; height: 60px; border-radius: 12px; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 1.6rem; }
        .trust-label { font-size: 0.75rem; color: var(--text-muted); text-align: center; }

        /* ===== CART DRAWER ===== */
        .cart-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 2000; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
        .cart-overlay.open { opacity: 1; pointer-events: all; }
        .cart-drawer { position: fixed; left: 0; top: 0; bottom: 0; width: 400px; background: white; z-index: 2001; transform: translateX(-100%); transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; box-shadow: 10px 0 60px rgba(0,0,0,0.2); }
        .cart-drawer.open { transform: translateX(0); }
        .cart-header { padding: 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
        .cart-title { font-size: 1.1rem; font-weight: 700; color: var(--brown-dark); }
        .cart-close { background: none; border: none; cursor: pointer; font-size: 1.2rem; color: var(--text-muted); padding: 6px; transition: color 0.2s; }
        .cart-close:hover { color: var(--brown-dark); }
        .cart-items { flex: 1; overflow-y: auto; padding: 20px 24px; }
        .cart-empty { text-align: center; padding: 60px 20px; color: var(--text-muted); }
        .cart-empty i { font-size: 3rem; margin-bottom: 16px; display: block; }
        .cart-item { display: flex; gap: 14px; padding: 16px 0; border-bottom: 1px solid var(--border); }
        .cart-item-img { width: 70px; height: 80px; border-radius: 8px; background: var(--cream2); display: flex; align-items: center; justify-content: center; font-size: 2rem; flex-shrink: 0; }
        .cart-item-info { flex: 1; }
        .cart-item-name { font-size: 0.9rem; font-weight: 600; color: var(--brown-dark); margin-bottom: 6px; }
        .cart-item-price { font-size: 0.85rem; color: var(--brown); font-weight: 700; }
        .cart-item-qty { display: flex; align-items: center; gap: 12px; margin-top: 10px; }
        .qty-btn { width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--border); background: none; cursor: pointer; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
        .qty-btn:hover { background: var(--brown-dark); color: white; border-color: var(--brown-dark); }
        .qty-num { font-size: 0.9rem; font-weight: 700; color: var(--brown-dark); }
        .cart-footer { padding: 24px; border-top: 1px solid var(--border); }
        .cart-total { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .cart-total-label { font-size: 0.9rem; color: var(--text-muted); }
        .cart-total-price { font-size: 1.2rem; font-weight: 900; color: var(--brown-dark); }
        .checkout-btn { width: 100%; padding: 16px; background: var(--brown-dark); color: white; border: none; border-radius: 8px; font-family: 'Vazirmatn', sans-serif; font-size: 0.95rem; font-weight: 700; cursor: pointer; transition: all 0.3s; letter-spacing: 1px; }
        .checkout-btn:hover { background: var(--brown); }

        /* ===== SEARCH ===== */
        .search-overlay { position: fixed; inset: 0; background: rgba(250,247,242,0.97); backdrop-filter: blur(20px); z-index: 2000; display: flex; align-items: flex-start; justify-content: center; padding-top: 120px; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
        .search-overlay.open { opacity: 1; pointer-events: all; }
        .search-box { width: 100%; max-width: 600px; padding: 0 30px; }
        .search-input-wrap { display: flex; align-items: center; gap: 16px; border-bottom: 2px solid var(--brown-dark); padding-bottom: 16px; margin-bottom: 30px; }
        .search-input { flex: 1; border: none; outline: none; font-family: 'Vazirmatn', sans-serif; font-size: 1.8rem; background: transparent; color: var(--brown-dark); }
        .search-input::placeholder { color: var(--border); }
        .search-close { background: none; border: none; cursor: pointer; font-size: 1.4rem; color: var(--text-muted); }

        /* ===== FOOTER ===== */
        footer { background: var(--brown-dark); color: white; padding: 70px 60px 30px; }
        .footer-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 50px; margin-bottom: 50px; }
        .footer-logo-main { font-size: 1.8rem; font-weight: 900; letter-spacing: 3px; color: white; margin-bottom: 4px; }
        .footer-logo-sub { font-size: 0.65rem; color: var(--brown-light); letter-spacing: 4px; margin-bottom: 18px; }
        .footer-desc { color: rgba(255,255,255,0.5); font-size: 0.85rem; line-height: 1.9; margin-bottom: 24px; }
        .footer-socials { display: flex; gap: 10px; }
        .footer-social { width: 38px; height: 38px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.9rem; transition: all 0.3s; }
        .footer-social:hover { background: var(--brown); border-color: var(--brown); color: white; }
        .footer-col-title { font-size: 0.8rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--brown-light); margin-bottom: 20px; }
        .footer-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
        .footer-links a { color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.88rem; transition: color 0.3s; }
        .footer-links a:hover { color: white; }
        .footer-bottom { max-width: 1200px; margin: 0 auto; padding-top: 30px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: space-between; }
        .footer-copy { font-size: 0.8rem; color: rgba(255,255,255,0.3); }
        .footer-pay { display: flex; gap: 10px; align-items: center; }
        .pay-badge { padding: 5px 12px; border: 1px solid rgba(255,255,255,0.15); border-radius: 6px; font-size: 0.72rem; color: rgba(255,255,255,0.4); }

        /* ===== SCROLL TOP ===== */
        .scroll-top { position: fixed; bottom: 30px; left: 30px; width: 46px; height: 46px; background: var(--brown-dark); color: white; border: none; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1rem; cursor: pointer; box-shadow: var(--shadow); opacity: 0; pointer-events: none; transition: all 0.3s; z-index: 500; }
        .scroll-top.show { opacity: 1; pointer-events: all; }
        .scroll-top:hover { background: var(--brown); transform: translateY(-3px); }

        /* ===== TOAST ===== */
        .toast { position: fixed; bottom: 30px; right: 30px; padding: 14px 24px; background: var(--brown-dark); color: white; border-radius: 10px; font-size: 0.88rem; font-weight: 600; display: flex; align-items: center; gap: 10px; z-index: 9999; transform: translateY(80px); opacity: 0; transition: all 0.4s; box-shadow: var(--shadow-hover); }
        .toast.show { transform: translateY(0); opacity: 1; }

        /* ===== REVEAL ===== */
        .reveal { opacity: 0; transform: translateY(30px); transition: all 0.7s cubic-bezier(0.4, 0, 0.2, 1); }
        .reveal.visible { opacity: 1; transform: translateY(0); }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 1100px) {
            .products-grid { grid-template-columns: repeat(3, 1fr); }
            .footer-grid { grid-template-columns: 1fr 1fr; gap: 30px; }
            .instagram-grid { grid-template-columns: repeat(3, 1fr); }
        }
        @media (max-width: 900px) {
            nav { padding: 0 24px; }
            .nav-center { display: none; }
            .hamburger { display: flex; }
            #hero { grid-template-columns: 1fr; min-height: auto; }
            .hero-left { padding: 60px 24px; text-align: center; }
            .hero-title { font-size: 2.6rem; }
            .hero-desc { margin: 0 auto 30px; }
            .hero-btns { justify-content: center; }
            .hero-stats { justify-content: center; }
            .hero-right { height: 350px; }
            .hero-img-wrap { width: 260px; height: 320px; }
            .hero-float-card { display: none; }
            #features { padding: 60px 24px; }
            .features-grid { grid-template-columns: repeat(2, 1fr); }
            #categories { padding: 70px 24px; }
            .categories-grid { grid-template-columns: 1fr 1fr; }
            #products { padding: 70px 24px; }
            .products-grid { grid-template-columns: repeat(2, 1fr); }
            #banner { padding: 50px 24px; }
            .banner-inner { padding: 40px; grid-template-columns: 1fr; text-align: center; }
            .banner-visual { display: none; }
            #testimonials { padding: 70px 24px; }
            .testimonials-grid { grid-template-columns: 1fr; }
            #instagram { padding: 70px 24px; }
            .instagram-grid { grid-template-columns: repeat(3, 1fr); }
            #newsletter { padding: 60px 24px; }
            #about { padding: 70px 24px; }
            .about-inner { grid-template-columns: 1fr; gap: 40px; }
            #contact { padding: 70px 24px; }
            .contact-inner { grid-template-columns: 1fr; }
            #trust { padding: 40px 24px; }
            .trust-inner { gap: 30px; }
            footer { padding: 50px 24px 24px; }
            .footer-grid { grid-template-columns: 1fr; gap: 30px; }
            .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }
            .cart-drawer { width: 100%; }
        }
        @media (max-width: 550px) {
            .products-grid { grid-template-columns: 1fr; }
            .form-row { grid-template-columns: 1fr; }
            .hero-title { font-size: 2rem; }
            .instagram-grid { grid-template-columns: repeat(2, 1fr); }
            .categories-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<!-- LOADER -->
