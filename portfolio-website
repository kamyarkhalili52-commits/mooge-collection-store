    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --cream: #FAF7F2;
            --cream2: #F2EDE4;
            --brown: #8B6F47;
            --brown-dark: #5C4A32;
            --brown-light: #C4A882;
            --text: #2C2416;
            --text-muted: #8B7355;
            --white: #FFFFFF;
            --border: #E8DDD0;
            --accent: #D4956A;
            --green: #7A9E7E;
            --shadow: 0 4px 30px rgba(139, 111, 71, 0.12);
            --shadow-hover: 0 20px 60px rgba(139, 111, 71, 0.2);
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--cream);
            color: var(--text);
            overflow-x: hidden;
        }

        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: var(--cream); }
        ::-webkit-scrollbar-thumb { background: var(--brown-light); border-radius: 5px; }

        /* ===== LOADER ===== */
        .loader {
            position: fixed;
            inset: 0;
            background: var(--cream);
            z-index: 99999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 0.6s, visibility 0.6s;
        }
        .loader.hidden { opacity: 0; visibility: hidden; }
        .loader-logo { font-size: 2.2rem; font-weight: 900; color: var(--brown-dark); letter-spacing: 4px; margin-bottom: 30px; }
        .loader-bar { width: 200px; height: 2px; background: var(--border); border-radius: 2px; overflow: hidden; }
        .loader-fill { height: 100%; background: linear-gradient(90deg, var(--brown), var(--accent)); border-radius: 2px; animation: load 1.8s ease forwards; }
        @keyframes load { from { width: 0; } to { width: 100%; } }

        /* ===== ANNOUNCE BAR ===== */
        .announce-bar {
            background: var(--brown-dark);
            color: white;
            text-align: center;
            padding: 10px 20px;
            font-size: 0.82rem;
            letter-spacing: 1px;
            position: relative;
            z-index: 100;
        }
        .announce-bar span { color: var(--brown-light); font-weight: 700; }

        /* ===== NAVBAR ===== */
        nav {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(250, 247, 242, 0.95);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            padding: 0 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 72px;
            transition: all 0.3s;
        }
        nav.scrolled { box-shadow: var(--shadow); }
        .nav-logo { display: flex; flex-direction: column; align-items: flex-end; }
        .nav-logo-main { font-size: 1.5rem; font-weight: 900; color: var(--brown-dark); letter-spacing: 3px; line-height: 1; }
        .nav-logo-sub { font-size: 0.65rem; color: var(--brown-light); letter-spacing: 4px; text-transform: uppercase; }
        .nav-center { display: flex; gap: 36px; list-style: none; }
        .nav-center a { color: var(--text-muted); text-decoration: none; font-size: 0.88rem; font-weight: 500; position: relative; transition: color 0.3s; }
        .nav-center a::after { content: ''; position: absolute; bottom: -3px; right: 0; width: 0; height: 1.5px; background: var(--brown); transition: width 0.3s; }
        .nav-center a:hover { color: var(--brown-dark); }
        .nav-center a:hover::after { width: 100%; }
        .nav-actions { display: flex; align-items: center; gap: 20px; }
        .nav-icon-btn { background: none; border: none; cursor: pointer; color: var(--text-muted); font-size: 1.1rem; position: relative; transition: color 0.3s; padding: 5px; }
        .nav-icon-btn:hover { color: var(--brown-dark); }
        .cart-badge { position: absolute; top: -4px; left: -4px; width: 18px; height: 18px; background: var(--accent); color: white; border-radius: 50%; font-size: 0.65rem; display: flex; align-items: center; justify-content: center; font-weight: 700; }
        .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 5px; }
        .hamburger span { display: block; width: 24px; height: 2px; background: var(--brown-dark); border-radius: 2px; transition: all 0.3s; }

        /* ===== MOBILE MENU ===== */
        .mobile-menu { position: fixed; inset: 0; background: var(--cream); z-index: 998; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 36px; opacity: 0; pointer-events: none; transition: all 0.4s; }
        .mobile-menu.open { opacity: 1; pointer-events: all; }
        .mobile-menu a { color: var(--brown-dark); text-decoration: none; font-size: 1.8rem; font-weight: 700; letter-spacing: 2px; transition: color 0.3s; }
        .mobile-menu a:hover { color: var(--accent); }

        /* ===== HERO ===== */
        #hero { min-height: calc(100vh - 112px); display: grid; grid-template-columns: 1fr 1fr; overflow: hidden; }
        .hero-left { display: flex; flex-direction: column; justify-content: center; padding: 80px 60px; background: var(--cream); }
        .hero-tag { display: inline-flex; align-items: center; gap: 8px; font-size: 0.75rem; color: var(--brown); letter-spacing: 3px; text-transform: uppercase; margin-bottom: 24px; }
        .hero-tag::before { content: ''; width: 30px; height: 1px; background: var(--brown); }
        .hero-title { font-size: 3.8rem; font-weight: 900; line-height: 1.2; color: var(--brown-dark); margin-bottom: 20px; }
        .hero-title em { font-style: normal; color: var(--accent); position: relative; }
        .hero-title em::after { content: ''; position: absolute; bottom: 4px; right: 0; left: 0; height: 3px; background: var(--accent); opacity: 0.3; border-radius: 2px; }
        .hero-desc { color: var(--text-muted); font-size: 1rem; line-height: 1.9; margin-bottom: 40px; max-width: 420px; }
        .hero-btns { display: flex; gap: 16px; flex-wrap: wrap; }
        .btn-dark { padding: 15px 38px; background: var(--brown-dark); color: white; border: none; border-radius: 4px; font-family: 'Vazirmatn', sans-serif; font-size: 0.9rem; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 10px; transition: all 0.3s; letter-spacing: 1px; }
        .btn-dark:hover { background: var(--brown); transform: translateY(-2px); box-shadow: 0 10px 30px rgba(92, 74, 50, 0.3); }
        .btn-outline { padding: 15px 38px; background: transparent; color: var(--brown-dark); border: 1.5px solid var(--brown-dark); border-radius: 4px; font-family: 'Vazirmatn', sans-serif; font-size: 0.9rem; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 10px; transition: all 0.3s; }
        .btn-outline:hover { background: var(--brown-dark); color: white; transform: translateY(-2px); }
        .hero-stats { display: flex; gap: 40px; margin-top: 50px; padding-top: 40px; border-top: 1px solid var(--border); }
        .hero-stat-num { font-size: 1.8rem; font-weight: 900; color: var(--brown-dark); line-height: 1; margin-bottom: 4px; }
        .hero-stat-label { font-size: 0.78rem; color: var(--text-muted); letter-spacing: 1px; }
        .hero-right { position: relative; background: var(--cream2); overflow: hidden; display: flex; align-items: center; justify-content: center; }
        .hero-bg-text { position: absolute; font-size: 12rem; font-weight: 900; color: rgba(139, 111, 71, 0.05); letter-spacing: -10px; user-select: none; white-space: nowrap; }
        .hero-img-wrap { position: relative; z-index: 1; width: 420px; height: 500px; }
        .hero-img-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, var(--cream2), var(--border)); border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; box-shadow: var(--shadow-hover); border: 1px solid var(--border); }
        .hero-float-card { position: absolute; background: white; border-radius: 12px; padding: 14px 18px; box-shadow: 0 10px 40px rgba(139, 111, 71, 0.15); display: flex; align-items: center; gap: 12px; font-size: 0.82rem; z-index: 2; animation: float 3s ease-in-out infinite; }
        .hero-float-card.card1 { bottom: 40px; right: -20px; animation-delay: 0s; }
        .hero-float-card.card2 { top: 40px; left: -20px; animation-delay: 1s; }
        .float-icon { width: 38px; height: 38px; border-radius: 10px; background: var(--cream2); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
        .float-card-text strong { display: block; font-weight: 700; color: var(--brown-dark); }
        .float-card-text span { color: var(--text-muted); font-size: 0.75rem; }
        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }

        /* ===== MARQUEE ===== */
        .marquee-section { background: var(--brown-dark); padding: 16px 0; overflow: hidden; white-space: nowrap; }
        .marquee-track { display: inline-flex; animation: marquee 20s linear infinite; }
        .marquee-item { display: inline-flex; align-items: center; gap: 20px; padding: 0 30px; color: var(--brown-light); font-size: 0.82rem; letter-spacing: 2px; text-transform: uppercase; }
        .marquee-item .dot { width: 4px; height: 4px; background: var(--accent); border-radius: 50%; }
        @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

        /* ===== SECTION BASE ===== */
        .section-header { text-align: center; margin-bottom: 60px; }
        .section-tag { display: inline-block; font-size: 0.72rem; letter-spacing: 4px; text-transform: uppercase; color: var(--brown); margin-bottom: 14px; position: relative; }
        .section-tag::before, .section-tag::after { content: '—'; margin: 0 8px; opacity: 0.5; }
        .section-title { font-size: 2.4rem; font-weight: 900; color: var(--brown-dark); margin-bottom: 14px; }
        .section-desc { color: var(--text-muted); font-size: 0.95rem; max-width: 450px; margin: 0 auto; line-height: 1.8; }

        /* ===== FEATURES ===== */
        #features { background: white; padding: 80px 60px; }
        .features-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
        .feature-item { background: white; padding: 36px 28px; text-align: center; transition: all 0.3s; }
        .feature-item:hover { background: var(--cream); }
        .feature-icon { width: 56px; height: 56px; border-radius: 14px; background: var(--cream2); display: flex; align-items: center; justify-content: center; margin: 0 auto 18px; font-size: 1.4rem; color: var(--brown); transition: all 0.3s; }
        .feature-item:hover .feature-icon { background: var(--brown-dark); color: white; }
        .feature-title { font-size: 0.95rem; font-weight: 700; color: var(--brown-dark); margin-bottom: 8px; }
        .feature-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.7; }

        /* ===== CATEGORIES ===== */
        #categories { padding: 100px 60px; background: var(--cream); }
        .categories-inner { max-width: 1200px; margin: 0 auto; }
        .categories-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
        .cat-card { position: relative; border-radius: 12px; overflow: hidden; cursor: pointer; background: var(--cream2); border: 1px solid var(--border); transition: all 0.4s; }
        .cat-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-hover); }
        .cat-placeholder { width: 100%; height: 280px; background: linear-gradient(135deg, var(--cream2), var(--border)); display: flex; align-items: center; justify-content: center; font-size: 4rem; transition: transform 0.6s ease; }
        .cat-card:hover .cat-placeholder { transform: scale(1.05); }
        .cat-body { padding: 22px 24px; display: flex; align-items: center; justify-content: space-between; }
        .cat-name { font-size: 1.05rem; font-weight: 700; color: var(--brown-dark); }
        .cat-count { font-size: 0.8rem; color: var(--text-muted); margin-top: 3px; }
        .cat-arrow { width: 38px; height: 38px; border-radius: 50%; background: var(--cream); border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--brown-dark); font-size: 0.9rem; transition: all 0.3s; }
        .cat-card:hover .cat-arrow { background: var(--brown-dark); color: white; border-color: var(--brown-dark); }

        /* ===== PRODUCTS ===== */
        #products { padding: 100px 60px; background: white; }
        .products-inner { max-width: 1200px; margin: 0 auto; }
        .products-filter { display: flex; justify-content: center; gap: 10px; margin-bottom: 50px; flex-wrap: wrap; }
        .filter-btn { padding: 9px 22px; border: 1.5px solid var(--border); background: transparent; color: var(--text-muted); border-radius: 50px; font-family: 'Vazirmatn', sans-serif; font-size: 0.85rem; cursor: pointer; transition: all 0.3s; }
        .filter-btn.active, .filter-btn:hover { background: var(--brown-dark); color: white; border-color: var(--brown-dark); }
        .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
        .product-card { border-radius: 12px; overflow: hidden; background: var(--cream); border: 1px solid var(--border); transition: all 0.4s; position: relative; }
        .product-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-hover); }
        .product-badge { position: absolute; top: 14px; right: 14px; padding: 4px 12px; border-radius: 50px; font-size: 0.7rem; font-weight: 700; z-index: 1; }
        .badge-new { background: var(--brown-dark); color: white; }
        .badge-sale { background: var(--accent); color: white; }
        .badge-hot { background: #E74C3C; color: white; }
        .product-img-wrap { position: relative; overflow: hidden; height: 240px; background: var(--cream2); }
        .product-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 4rem; background: linear-gradient(135deg, var(--cream2), var(--border)); transition: transform 0.6s ease; }
        .product-card:hover .product-placeholder { transform: scale(1.06); }
        .product-actions { position: absolute; bottom: -50px; left: 0; right: 0; display: flex; gap: 8px; padding: 10px; transition: bottom 0.3s ease; justify-content: center; }
        .product-card:hover .product-actions { bottom: 10px; }
        .action-btn { padding: 9px 18px; background: var(--brown-dark); color: white; border: none; border-radius: 6px; font-family: 'Vazirmatn', sans-serif; font-size: 0.78rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 7px; transition: all 0.2s; white-space: nowrap; }
        .action-btn:hover { background: var(--brown); }
        .action-btn-icon { width: 36px; height: 36px; background: white; color: var(--brown-dark); border: none; border-radius: 6px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 0.9rem; transition: all 0.2s; }
        .action-btn-icon:hover { background: var(--cream2); }
        .product-body { padding: 18px; }
        .product-cat { font-size: 0.72rem; color: var(--brown); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 6px; }
        .product-name { font-size: 0.95rem; font-weight: 700; color: var(--brown-dark); margin-bottom: 10px; }
        .product-footer { display: flex; align-items: center; justify-content: space-between; }
        .product-price { font-size: 1rem; font-weight: 900; color: var(--brown-dark); }
        .product-price .old { font-size: 0.78rem; color: var(--text-muted); text-decoration: line-through; font-weight: 400; margin-right: 6px; }
        .product-colors { display: flex; gap: 5px; }
        .color-dot { width: 14px; height: 14px; border-radius: 50%; border: 1.5px solid var(--border); cursor: pointer; transition: transform 0.2s; }
        .color-dot:hover { transform: scale(1.3); }

        /* ===== BANNER ===== */
        #banner { padding: 80px 60px; background: var(--cream2); }
        .banner-inner { max-width: 1200px; margin: 0 auto; background: var(--brown-dark); border-radius: 20px; padding: 60px 80px; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; position: relative; overflow: hidden; }
        .banner-bg { position: absolute; inset: 0; opacity: 0.03; background-image: repeating-linear-gradient(45deg, white 0, white 1px, transparent 0, transparent 50%); background-size: 20px 20px; }
        .banner-text { position: relative; z-index: 1; }
        .banner-tag { font-size: 0.72rem; color: var(--brown-light); letter-spacing: 4px; text-transform: uppercase; margin-bottom: 16px; }
        .banner-title { font-size: 2.4rem; font-weight: 900; color: white; line-height: 1.3; margin-bottom: 16px; }
        .banner-desc { color: rgba(255,255,255,0.6); font-size: 0.95rem; line-height: 1.8; margin-bottom: 30px; }
        .banner-visual { position: relative; z-index: 1; display: flex; justify-content: center; }
        .banner-img-wrap { width: 260px; height: 320px; border-radius: 12px; background: rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; font-size: 6rem; border: 1px solid rgba(255,255,255,0.1); }

        /* ===== TESTIMONIALS ===== */
        #testimonials { padding: 100px 60px; background: white; }
        .testimonials-inner { max-width: 1200px; margin: 0 auto; }
        .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
        .testimonial-card { padding: 32px; background: var(--cream); border: 1px solid var(--border); border-radius: 16px; transition: all 0.3s; }
        .testimonial-card:hover { border-color: var(--brown-light); box-shadow: var(--shadow); transform: translateY(-4px); }
